{
  "editor.formatOnSave": true,
  "editor.defaultFormatter": "esbenp.prettier-vscode",
  "editor.inlineSuggest.enabled": true,
  "editor.quickSuggestions": {
    "comments": "on",
    "strings": "on",
    "other": "on"
  },
  "editor.suggestOnTriggerCharacters": true,
  "editor.wordBasedSuggestions": "allDocuments",
  "editor.parameterHints.enabled": true,
  "editor.acceptSuggestionOnEnter": "on",
  "javascript.suggest.autoImports": true,
  "typescript.suggest.autoImports": true,
  "emmet.showExpandedAbbreviation": "always",
  "editor.hover.enabled": "on",

  "antigravity.inlineSuggestions.enabled": false,
  "antigravity.completions.enabled": false,
  "antigravity.enableCodeSuggestions": false,
  "antigravity.tab.enabled": false,
  "antigravity.tab.suggestions": "off",
  "antigravity.suggestions.showInEditor": false,
  "antigravity.ghostText.enabled": false,
  "github.copilot.enable": {
    "*": false,
    "plaintext": false,
    "markdown": false,
    "scminput": false
  }
}
